// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Note: `url` is no longer supported in schema files in Prisma 7+.
  // Move connection URLs for Migrate to prisma.config.ts and provide
  // an `adapter` or `accelerateUrl` to the PrismaClient constructor.
  // See: https://pris.ly/d/config-datasource and https://pris.ly/d/prisma7-client-config
}


// declare users model(schema )

model User {
  id Int @id @default( autoincrement() )
  name String
  email String @unique
  password String
  role Role @default(USER)
  phone String?
  pictures String?
  status Status @default(ACTIVE)
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts Post[]
}
enum Status {
  ACTIVE
  INACTIVE
  PENDING
}
enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}


model Post {
  id Int @id @default( autoincrement() )
  title String
  content String
  thumbnail String?
  isFeatured Boolean @default(false)
  tags String[]
  viewCount Int @default(0)
  authorId Int
  author User @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}







